
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>海運マーケット分析フレームワーク</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&display=swap');

  :root {
    --bg: #0a0e1a;
    --surface: #111827;
    --surface2: #1a2236;
    --border: #1e2d45;
    --text: #e2e8f0;
    --muted: #64748b;
    --accent: #38bdf8;

    --bulker: #f59e0b;
    --bulker-dim: rgba(245,158,11,0.12);
    --bulker-border: rgba(245,158,11,0.35);

    --container: #22d3ee;
    --container-dim: rgba(34,211,238,0.10);
    --container-border: rgba(34,211,238,0.35);

    --tanker: #a78bfa;
    --tanker-dim: rgba(167,139,250,0.10);
    --tanker-border: rgba(167,139,250,0.35);

    --demand: #34d399;
    --supply: #fb7185;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── Header ── */
  header {
    padding: 32px 40px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-end;
    gap: 24px;
  }
  .header-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 38px;
    letter-spacing: 3px;
    color: #fff;
    line-height: 1;
  }
  .header-sub {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  /* ── Tab nav ── */
  .tab-nav {
    display: flex;
    gap: 0;
    padding: 0 40px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .tab-btn {
    padding: 14px 28px;
    border: none;
    background: none;
    color: var(--muted);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
    letter-spacing: 0.5px;
  }
  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.2s;
  }
  .tab-btn.active { color: #fff; }
  .tab-btn[data-tab="bulker"].active::after { background: var(--bulker); }
  .tab-btn[data-tab="container"].active::after { background: var(--container); }
  .tab-btn[data-tab="tanker"].active::after { background: var(--tanker); }
  .tab-btn[data-tab="framework"].active::after { background: var(--accent); }
  .tab-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: middle;
  }

  /* ── Main content ── */
  main { padding: 32px 40px; max-width: 1200px; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── Section heading ── */
  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }
  .section-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    padding: 4px 10px;
    border-radius: 2px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .badge-bulker { background: var(--bulker-dim); color: var(--bulker); border: 1px solid var(--bulker-border); }
  .badge-container { background: var(--container-dim); color: var(--container); border: 1px solid var(--container-border); }
  .badge-tanker { background: var(--tanker-dim); color: var(--tanker); border: 1px solid var(--tanker-border); }
  .badge-framework { background: rgba(56,189,248,0.1); color: var(--accent); border: 1px solid rgba(56,189,248,0.3); }
  .badge-signals { background: rgba(244,114,182,0.1); color: #f472b6; border: 1px solid rgba(244,114,182,0.35); }
  .badge-dashboard { background: rgba(74,222,128,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.35); }
  .tab-btn[data-tab="signals"].active::after { background: #f472b6; }
  .tab-btn[data-tab="dashboard"].active::after { background: #4ade80; }

  /* ── Dashboard tab ── */  .dash-intro {
    background: linear-gradient(135deg, rgba(74,222,128,0.08), rgba(56,189,248,0.05));
    border: 1px solid rgba(74,222,128,0.25);
    border-radius: 6px;
    padding: 18px 22px;
    margin-bottom: 20px;
    font-size: 13px;
    line-height: 1.6;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .dash-intro-icon {
    font-size: 22px;
    flex-shrink: 0;
  }
  .dash-intro strong { color: #4ade80; }

  .live-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: #4ade80;
    margin-bottom: 10px;
  }
  .live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .dash-section-title {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 24px 0 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .dash-section-title .count-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-left: auto;
    font-weight: 400;
  }

  .chart-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }
  .chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px;
    overflow: hidden;
  }
  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
  }
  .chart-name {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }
  .chart-sub {
    font-size: 10px;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    margin-top: 2px;
  }
  .chart-relevance {
    font-size: 11px;
    color: var(--text);
    margin-top: 8px;
    padding-top: 10px;
    border-top: 1px dashed var(--border);
    line-height: 1.5;
  }
  .chart-relevance-label {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    color: #4ade80;
    letter-spacing: 1px;
    margin-right: 6px;
  }
  .tv-container {
    height: 180px;
    position: relative;
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .link-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 14px 16px;
    text-decoration: none;
    color: var(--text);
    display: block;
    transition: all 0.2s ease;
    position: relative;
  }
  .link-card:hover {
    border-color: #4ade80;
    background: var(--surface2);
    transform: translateY(-1px);
  }
  .link-card::after {
    content: '↗';
    position: absolute;
    top: 14px;
    right: 14px;
    color: var(--muted);
    font-size: 14px;
    transition: color 0.2s;
  }
  .link-card:hover::after { color: #4ade80; }
  .link-title {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
    padding-right: 20px;
  }
  .link-source {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }
  .link-note {
    font-size: 11px;
    color: var(--text);
    line-height: 1.5;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed var(--border);
  }
  .link-freq-tag {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    padding: 1px 6px;
    border-radius: 2px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-right: 6px;
    vertical-align: middle;
  }
  .freq-tag-daily { background: rgba(244,114,182,0.15); color: #f472b6; }
  .freq-tag-weekly { background: rgba(56,189,248,0.15); color: var(--accent); }
  .freq-tag-monthly { background: rgba(167,139,250,0.15); color: #a78bfa; }

  .caveat-card {
    background: rgba(251,191,36,0.06);
    border: 1px solid rgba(251,191,36,0.25);
    border-radius: 4px;
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 12px;
    line-height: 1.6;
    color: var(--text);
  }
  .caveat-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: #fbbf24;
    letter-spacing: 1.5px;
    margin-bottom: 5px;
  }
  .section-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }

  /* ── Grid layouts ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 16px; }

  /* ── Card ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
  }
  .card-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .card-title-icon { font-size: 14px; }

  /* ── Factor list ── */
  .factor-list { list-style: none; }
  .factor-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .factor-item:last-child { border-bottom: none; }
  .factor-icon {
    font-size: 16px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .factor-text { flex: 1; }
  .factor-label {
    font-weight: 600;
    color: #fff;
    font-size: 12px;
  }
  .factor-desc {
    color: var(--muted);
    font-size: 12px;
    margin-top: 2px;
    line-height: 1.5;
  }
  .tag {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    padding: 1px 6px;
    border-radius: 2px;
    margin-left: 6px;
    vertical-align: middle;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .tag-demand { background: rgba(52,211,153,0.15); color: var(--demand); }
  .tag-supply { background: rgba(251,113,133,0.15); color: var(--supply); }
  .tag-geo { background: rgba(251,191,36,0.12); color: #fbbf24; }
  .tag-macro { background: rgba(167,139,250,0.12); color: #a78bfa; }
  .tag-structural { background: rgba(34,197,94,0.12); color: #22c55e; }
  .tag-critical { background: rgba(239,68,68,0.15); color: #ef4444; }

  /* ── Deep-dive evidence boxes ── */
  .evidence-box {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--bulker);
    border-radius: 4px;
    padding: 12px 14px;
    margin: 8px 0;
    font-size: 11.5px;
    line-height: 1.55;
    color: var(--text);
  }
  .evidence-box.container-color { border-left-color: var(--container); }
  .evidence-box.tanker-color { border-left-color: var(--tanker); }
  .evidence-box-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .evidence-box strong { color: #fff; }
  .evidence-box em { color: #fbbf24; font-style: normal; font-weight: 600; }

  .key-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    padding: 2px 8px;
    background: rgba(56,189,248,0.12);
    border-radius: 3px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10.5px;
    color: #7dd3fc;
    font-weight: 600;
    margin: 1px 2px;
    vertical-align: middle;
  }

  .driver-category {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 18px;
    overflow: hidden;
  }
  .driver-header {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(90deg, var(--surface2), transparent);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .driver-icon-large { font-size: 22px; }
  .driver-title-main {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
  }
  .driver-subtitle {
    font-size: 10.5px;
    color: var(--muted);
    margin-top: 2px;
  }
  .driver-body { padding: 12px 18px 16px; }

  .detail-row {
    padding: 14px 0;
    border-bottom: 1px dashed var(--border);
  }
  .detail-row:last-child { border-bottom: none; padding-bottom: 4px; }
  .detail-row-header {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 7px;
    flex-wrap: wrap;
  }
  .detail-row-title {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }
  .detail-row-body {
    font-size: 12px;
    color: var(--text);
    line-height: 1.65;
  }
  .detail-row-body em { color: #fbbf24; font-style: normal; font-weight: 500; }
  .detail-row-body strong { color: #fff; }

  .watchpoint {
    background: rgba(239,68,68,0.06);
    border: 1px solid rgba(239,68,68,0.22);
    border-radius: 4px;
    padding: 9px 12px;
    margin-top: 9px;
    font-size: 11px;
    color: var(--text);
    line-height: 1.55;
  }
  .watchpoint-label {
    display: inline-block;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: #ef4444;
    text-transform: uppercase;
    margin-right: 6px;
    font-weight: 600;
  }

  .market-snapshot {
    background: linear-gradient(135deg, rgba(251,191,36,0.08), rgba(239,68,68,0.06));
    border: 1px solid rgba(251,191,36,0.3);
    border-radius: 6px;
    padding: 16px 20px;
    margin-bottom: 20px;
  }
  .snapshot-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: #fbbf24;
    margin-bottom: 8px;
  }
  .snapshot-body {
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--text);
  }
  .snapshot-body strong { color: #fff; }


  /* ── Sub-type table ── */
  .subtype-grid {
    display: grid;
    gap: 10px;
    margin-bottom: 16px;
  }
  .subtype-row {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px 16px;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 12px;
    align-items: start;
  }
  .subtype-name {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
  }
  .subtype-dwt {
    font-size: 10px;
    color: var(--muted);
    margin-top: 2px;
  }
  .subtype-desc { font-size: 12px; color: var(--text); line-height: 1.5; }

  /* ── Divider label ── */
  .divider-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin: 24px 0 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .divider-label::before, .divider-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .divider-label::before { max-width: 20px; }

  /* ── KPI row ── */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }
  .kpi-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 14px;
    text-align: center;
  }
  .kpi-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .kpi-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    line-height: 1;
  }
  .kpi-sub {
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* ── Framework tab ── */
  .framework-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .fw-title {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .fw-title-icon { font-size: 20px; }
  .flow-row {
    display: flex;
    align-items: stretch;
    gap: 0;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .flow-box {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px 16px;
    font-size: 12px;
    line-height: 1.5;
    flex: 1;
    min-width: 120px;
  }
  .flow-box strong { display: block; color: #fff; font-size: 11px; margin-bottom: 3px; }
  .flow-arrow {
    display: flex;
    align-items: center;
    padding: 0 8px;
    color: var(--muted);
    font-size: 18px;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .comparison-table th {
    background: var(--surface2);
    padding: 10px 14px;
    text-align: left;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--muted);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
  }
  .comparison-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.5;
  }
  .comparison-table tr:last-child td { border-bottom: none; }
  .comparison-table td:first-child {
    font-weight: 600;
    color: #fff;
    width: 140px;
  }
  .col-b { color: var(--bulker); }
  .col-c { color: var(--container); }
  .col-t { color: var(--tanker); }

  /* ── Signals tab ── */
  .signal-intro {
    background: linear-gradient(135deg, rgba(244,114,182,0.08), rgba(56,189,248,0.05));
    border: 1px solid rgba(244,114,182,0.25);
    border-radius: 6px;
    padding: 20px 24px;
    margin-bottom: 24px;
    line-height: 1.7;
  }
  .signal-intro-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: #f472b6;
    margin-bottom: 8px;
  }
  .signal-intro-text { color: var(--text); font-size: 13px; }
  .signal-intro-text strong { color: #fff; }

  .routine-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }
  .routine-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .routine-freq {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    padding: 4px 12px;
    border-radius: 3px;
  }
  .freq-daily { background: rgba(244,114,182,0.15); color: #f472b6; }
  .freq-weekly { background: rgba(56,189,248,0.15); color: var(--accent); }
  .freq-monthly { background: rgba(167,139,250,0.15); color: #a78bfa; }
  .routine-title { font-size: 16px; color: #fff; font-weight: 700; }
  .routine-time {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    margin-left: auto;
    letter-spacing: 1px;
  }
  .signal-item {
    padding: 12px 0;
    border-bottom: 1px dashed var(--border);
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 20px;
